}).join(””);
document.getElementById(“modal-overlay”).classList.remove(“hidden”);
}
function closeModal() { document.getElementById(“modal-overlay”).classList.add(“hidden”); state.editingId=null; }

function saveRecord() {
const cat=CATEGORIAS.find(c=>c.id===state.activeCat); if(!cat) return;
const firstKey=cat.campos[0].key;
const firstVal=document.getElementById(“field-”+firstKey)?.value?.trim();
if(!firstVal) { alert(“Por favor preenche o campo: “+cat.campos[0].label); return; }
const record={};
cat.campos.forEach(campo=>{ const el=document.getElementById(“field-”+campo.key); if(el) record[campo.key]=el.value.trim(); });
if(!state.registos[cat.id]) state.registos[cat.id]=[];
if(state.editingId) {
const idx=state.registos[cat.id].findIndex(r=>r._id===state.editingId);
if(idx>=0) state.registos[cat.id][idx]={…record,_id:state.editingId};
} else { record._id=Date.now().toString()+Math.random().toString(36).slice(2); state.registos[cat.id].push(record); }
save(); closeModal(); renderList();
}

function openDetail(itemId) {
const cat=CATEGORIAS.find(c=>c.id===state.activeCat); if(!cat) return;
const item=getList(cat.id).find(r=>r._id===itemId); if(!item) return;
state.detailItem=item; state.detailCat=cat;
const iw=document.getElementById(“detail-icon-wrap”); iw.style.background=cat.cor+“22”; iw.textContent=cat.icon;
document.getElementById(“detail-cat-label”).textContent=cat.label;
document.getElementById(“detail-main-title”).textContent=item[cat.campos[0].key]||“Sem título”;
document.getElementById(“detail-fields”).innerHTML=cat.campos.map(campo=>{
const val=item[campo.key]; if(!val) return “”;
return `<div class="detail-field"><p class="detail-field-label">${campo.label}</p><p class="detail-field-val">${esc(val)}</p></div>`;
}).join(””);
document.getElementById(“detail-overlay”).classList.remove(“hidden”);
}
function closeDetail() { document.getElementById(“detail-overlay”).classList.add(“hidden”); state.detailItem=null; state.detailCat=null; }
function editCurrent() { if(!state.detailItem) return; const id=state.detailItem._id; closeDetail(); openModal(id); }
function deleteCurrent() {
if(!state.detailItem||!state.detailCat) return;
if(!confirm(“Eliminar este registo?”)) return;
const catId=state.detailCat.id;
state.registos[catId]=(state.registos[catId]||[]).filter(r=>r._id!==state.detailItem._id);
save(); closeDetail(); renderList();
}
function esc(str) { return String(str||””).replace(/&/g,”&”).replace(/</g,”<”).replace(/>/g,”>”).replace(/”/g,”"”); }

load(); showDashboard();
</script>

