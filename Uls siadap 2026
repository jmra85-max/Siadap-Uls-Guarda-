<script>
const CATEGORIAS = [
  { id:"formacoes_recebidas", label:"Formações Recebidas", icon:"📚", cor:"#2563eb", unidade:"formações", siadapRef:"Desenvolvimento Profissional",
    campos:[{key:"titulo",label:"Título da Formação",tipo:"texto"},{key:"entidade",label:"Entidade Formadora",tipo:"texto"},{key:"horas",label:"Nº de Horas",tipo:"numero"},{key:"data",label:"Data",tipo:"data"},{key:"area",label:"Área Temática",tipo:"select",opcoes:["Clínica","Gestão","Informática","Qualidade","Outra"]}]},
  { id:"formacoes_ministradas", label:"Formações Ministradas", icon:"🎓", cor:"#7c3aed", unidade:"formações", siadapRef:"Formação e Transferência de Conhecimento",
    campos:[{key:"titulo",label:"Título da Formação",tipo:"texto"},{key:"publico",label:"Público-Alvo",tipo:"texto"},{key:"horas",label:"Nº de Horas",tipo:"numero"},{key:"participantes",label:"Nº de Participantes",tipo:"numero"},{key:"data",label:"Data",tipo:"data"}]},
  { id:"trabalhos_servico", label:"Trabalhos para o Serviço", icon:"📋", cor:"#059669", unidade:"trabalhos", siadapRef:"Resultados / Objetivos",
    campos:[{key:"titulo",label:"Descrição do Trabalho",tipo:"texto"},{key:"tipo",label:"Tipo",tipo:"select",opcoes:["Relatório","Protocolo","Manual","Procedimento","Projeto","Outro"]},{key:"impacto",label:"Impacto",tipo:"select",opcoes:["Serviço","Departamento","ULS Guarda","Externo"]},{key:"data",label:"Data de Conclusão",tipo:"data"},{key:"notas",label:"Observações",tipo:"textarea"}]},
  { id:"reunioes", label:"Reuniões e Grupos de Trabalho", icon:"🤝", cor:"#d97706", unidade:"reuniões", siadapRef:"Participação Institucional",
    campos:[{key:"titulo",label:"Designação",tipo:"texto"},{key:"tipo",label:"Tipo",tipo:"select",opcoes:["Reunião de Serviço","Grupo de Trabalho","Comissão","Outra"]},{key:"data",label:"Data",tipo:"data"},{key:"duracao",label:"Duração (minutos)",tipo:"numero"}]},
  { id:"publicacoes", label:"Publicações e Comunicações", icon:"📰", cor:"#dc2626", unidade:"publicações", siadapRef:"Produção Científica",
    campos:[{key:"titulo",label:"Título",tipo:"texto"},{key:"tipo",label:"Tipo",tipo:"select",opcoes:["Artigo Científico","Comunicação Oral","Poster","Capítulo de Livro","Outro"]},{key:"evento",label:"Publicação / Evento",tipo:"texto"},{key:"data",label:"Data",tipo:"data"}]},
  { id:"projetos", label:"Projetos e Inovação", icon:"🚀", cor:"#0891b2", unidade:"projetos", siadapRef:"Iniciativa e Inovação",
    campos:[{key:"titulo",label:"Nome do Projeto",tipo:"texto"},{key:"estado",label:"Estado",tipo:"select",opcoes:["Em curso","Concluído","Suspenso"]},{key:"papel",label:"Papel no Projeto",tipo:"select",opcoes:["Responsável","Colaborador","Consultor"]},{key:"data",label:"Data de Início",tipo:"data"},{key:"notas",label:"Descrição",tipo:"textarea"}]},
  { id:"orientacao_alunos", label:"Orientação de Alunos", icon:"🎒", cor:"#16a34a", unidade:"orientações", siadapRef:"Ensino e Supervisão Clínica",
    campos:[{key:"aluno",label:"Nome do Aluno",tipo:"texto"},{key:"escola",label:"Escola / Universidade",tipo:"texto"},{key:"curso",label:"Curso",tipo:"texto"},{key:"tipo",label:"Tipo de Orientação",tipo:"select",opcoes:["Estágio Clínico","Ensino Clínico","Dissertação / Tese","Outro"]},{key:"data_inicio",label:"Data de Início",tipo:"data"},{key:"data_fim",label:"Data de Fim",tipo:"data"},{key:"notas",label:"Observações",tipo:"textarea"}]},
  { id:"turnos_extra", label:"Turnos Extra", icon:"🕐", cor:"#e11d48", unidade:"turnos", siadapRef:"Disponibilidade e Dedicação",
    campos:[{key:"titulo",label:"Motivo / Descrição",tipo:"texto"},{key:"tipo",label:"Tipo de Turno",tipo:"select",opcoes:["Reforço de Equipa","Substituição","Urgência / Emergência","Outro"]},{key:"data",label:"Data",tipo:"data"},{key:"horas",label:"Nº de Horas",tipo:"numero"},{key:"servico",label:"Serviço",tipo:"texto"},{key:"notas",label:"Observações",tipo:"textarea"}]},
];

let state = { view:"dashboard", activeCat:null, editingId:null, detailItem:null, detailCat:null, registos:{} };

function load() { try { const s=localStorage.getItem("siadap_registos_v2"); if(s) state.registos=JSON.parse(s); } catch(e){} }
function save() { try { localStorage.setItem("siadap_registos_v2", JSON.stringify(state.registos)); } catch(e){} }
function getList(id) { return state.registos[id]||[]; }
function totalFor(id) { return getList(id).length; }
function grandTotal() { return CATEGORIAS.reduce((s,c)=>s+totalFor(c.id),0); }

function renderDashboard() {
  document.getElementById("total-num").textContent = grandTotal();
  document.getElementById("cat-grid").innerHTML = CATEGORIAS.map(c=>`
    <button class="cat-card" onclick="goToList('${c.id}')">
      <span class="cat-icon">${c.icon}</span>
      <span class="cat-count" style="background:${c.cor}22;color:${c.cor}">${totalFor(c.id)}</span>
      <p class="cat-name">${c.label}</p>
    </button>`).join("");
  document.getElementById("siadap-box").innerHTML = CATEGORIAS.map(c=>`
    <div class="siadap-row">
      <div class="siadap-left"><span style="font-size:14px">${c.icon}</span><span class="siadap-ref">${c.siadapRef}</span></div>
      <span style="font-size:14px;font-weight:700;color:${c.cor}">${totalFor(c.id)}</span>
    </div>`).join("");
}

function renderList() {
  const cat = CATEGORIAS.find(c=>c.id===state.activeCat); if(!cat) return;
  const items = getList(cat.id);
  document.getElementById("list-count").textContent = `${items.length} ${cat.unidade}`;
  document.getElementById("btn-add-main").style.background = cat.cor;
  document.getElementById("empty-icon").textContent = cat.icon;
  const empty = document.getElementById("list-empty");
  const list = document.getElementById("record-list");
  if(items.length===0) { empty.classList.remove("hidden"); list.innerHTML=""; }
  else {
    empty.classList.add("hidden");
    list.innerHTML = items.map(item=>`
      <button class="record-btn" onclick="openDetail('${item._id}')">
        <div class="record-icon-wrap" style="background:${cat.cor}22">${cat.icon}</div>
        <div class="record-info">
          <div class="record-title">${esc(item[cat.campos[0].key]||"Sem título")}</div>
          <div class="record-sub">${[item.data||item.data_inicio,item.horas?item.horas+"h":null,item.participantes?item.participantes+" part.":null].filter(Boolean).join(" · ")}</div>
        </div>
        <span class="record-arrow">›</span>
      </button>`).join("");
  }
}

function renderReport() {
  document.getElementById("report-date").textContent = `ULS Guarda · Gerado em ${new Date().toLocaleDateString("pt-PT")}`;
  const maxVal = Math.max(...CATEGORIAS.map(c=>totalFor(c.id)),1);
  document.getElementById("report-bars").innerHTML = CATEGORIAS.map(c=>{
    const t=totalFor(c.id);
    return `<div class="bar-row"><div class="bar-label"><span class="bar-name">${c.icon} ${c.label}</span><span class="bar-val" style="color:${c.cor}">${t}</span></div><div class="bar-track"><div class="bar-fill" style="width:${(t/maxVal)*100}%;background:${c.cor}"></div></div></div>`;
  }).join("");
  const detail = CATEGORIAS.map(c=>{
    const items=getList(c.id); if(!items.length) return "";
    return `<div class="detail-section"><p class="detail-cat" style="color:${c.cor}">${c.icon} ${c.label} (${items.length})</p>${items.map(it=>`<p class="detail-item">· ${esc(it[c.campos[0].key]||"")}${it.data?" ("+it.data+")":it.data_inicio?" ("+it.data_inicio+")":""}</p>`).join("")}</div>`;
  }).join("");
  document.getElementById("report-detail").innerHTML = detail||`<p style="font-size:13px;color:var(--dim);text-align:center">Sem registos para mostrar</p>`;
}

function setActiveTab(name) {
  ["dashboard","list","orientacao","turnos","report"].forEach(t=>{
    const tab=document.getElementById("tab-"+t); if(!tab) return;
    const lbl=tab.querySelector(".tab-label");
    lbl.style.color = t===name?"var(--blue)":"var(--dim)";
    lbl.style.fontWeight = t===name?"700":"400";
  });
}

function showDashboard() {
  state.view="dashboard";
  document.getElementById("page-title").textContent="O Meu Registo";
  document.getElementById("view-dashboard").classList.remove("hidden");
  document.getElementById("view-list").classList.add("hidden");
  document.getElementById("view-report").classList.add("hidden");
  setActiveTab("dashboard"); renderDashboard();
}
function goToList(catId) { state.activeCat=catId; showList(); }
function showList() {
  if(!state.activeCat) state.activeCat=CATEGORIAS[0].id;
  state.view="list";
  const cat=CATEGORIAS.find(c=>c.id===state.activeCat);
  document.getElementById("page-title").textContent=cat?cat.label:"Registos";
  document.getElementById("view-dashboard").classList.add("hidden");
  document.getElementById("view-list").classList.remove("hidden");
  document.getElementById("view-report").classList.add("hidden");
  setActiveTab("list"); renderList();
}
function showReport() {
  state.view="report";
  document.getElementById("page-title").textContent="Relatório";
  document.getElementById("view-dashboard").classList.add("hidden");
  document.getElementById("view-list").classList.add("hidden");
  document.getElementById("view-report").classList.remove("hidden");
  setActiveTab("report"); renderReport();
}

function openModal(editId) {
  const cat=CATEGORIAS.find(c=>c.id===state.activeCat); if(!cat) return;
  let existing=null;
  if(editId) { existing=getList(cat.id).find(r=>r._id===editId); state.editingId=editId; } else { state.editingId=null; }
  document.getElementById("modal-title").textContent=(editId?"Editar":"Novo")+" · "+cat.label;
  document.getElementById("btn-save").textContent=editId?"Guardar Alterações":"Adicionar Registo";
  document.getElementById("btn-save").style.background=`linear-gradient(135deg,${cat.cor},${cat.cor}bb)`;
  document.getElementById("modal-fields").innerHTML = cat.campos.map(campo=>{
    const val=existing?(existing[campo.key]||"):"";
    let input="";
    if(campo.tipo==="texto") input=`<input type="text" id="field-${campo.key}" value="${esc(val)}" placeholder="${campo.label}">`;
    else if(campo.tipo==="numero") input=`<input type="number" id="field-${campo.key}" value="${esc(val)}" placeholder="0" inputmode="numeric">`;
    else if(campo.tipo==="data") input=`<input type="date" id="field-${campo.key}" value="${esc(val)}">`;
    else if(campo.tipo==="textarea") input=`<textarea id="field-${campo.key}" rows="3" placeholder="${campo.label}">${esc(val)}</textarea>`;

```
else if(campo.tipo==="select") { const opts=campo.opcoes.map(o=>`<option value="${o}"${val===o?" selected":""}>${o}</option>`).join(""); input=`<select id="field-${campo.key}"><option value="">Selecionar...</option>${opts}</select>`; }
return `<div class="field-wrap"><label class="field-label">${campo.label}</label>${input}</div>`;
