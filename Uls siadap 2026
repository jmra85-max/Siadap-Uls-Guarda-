<!DOCTYPE html>

<html lang="pt">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="SIADAP Guarda">
<meta name="theme-color" content="#0f172a">
<title>SIADAP 2026 · ULS Guarda</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
  :root {
    --bg: #0f172a; --bg2: #1e293b; --bg3: #243047; --border: #334155;
    --text: #f1f5f9; --muted: #94a3b8; --dim: #64748b;
    --blue: #3b82f6; --purple: #7c3aed; --green: #059669; --amber: #d97706; --red: #dc2626; --cyan: #0891b2;
    --safe-top: env(safe-area-inset-top, 0px); --safe-bot: env(safe-area-inset-bottom, 0px);
  }
  body { font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; min-height: 100dvh; overflow-x: hidden; overscroll-behavior: none; }
  #app { max-width: 430px; margin: 0 auto; min-height: 100vh; min-height: 100dvh; position: relative; overflow: hidden; display: flex; flex-direction: column; }
  .header { padding: calc(var(--safe-top) + 52px) 20px 12px; background: linear-gradient(180deg, #0f172a 70%, transparent); position: sticky; top: 0; z-index: 10; }
  .header-top { display: flex; justify-content: space-between; align-items: flex-start; }
  .header-subtitle { font-size: 11px; color: var(--dim); letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 4px; }
  .header-title { font-size: 26px; font-weight: 800; letter-spacing: -0.5px; }
  .avatar { width: 44px; height: 44px; border-radius: 14px; background: linear-gradient(135deg, var(--blue), var(--purple)); display: flex; align-items: center; justify-content: center; font-size: 20px; box-shadow: 0 4px 15px rgba(59,130,246,0.4); flex-shrink: 0; }
  .content { flex: 1; overflow-y: auto; -webkit-overflow-scrolling: touch; padding: 0 16px calc(90px + var(--safe-bot)); }
  .total-card { background: linear-gradient(135deg, var(--blue) 0%, var(--purple) 100%); border-radius: 20px; padding: 20px 24px; margin-bottom: 20px; box-shadow: 0 8px 30px rgba(59,130,246,0.3); }
  .total-card p { margin: 0; }
  .total-label { font-size: 13px; opacity: 0.8; letter-spacing: 0.5px; }
  .total-num { font-size: 52px; font-weight: 800; line-height: 1; margin: 4px 0 0 !important; }
  .total-sub { font-size: 12px; opacity: 0.7; margin: 8px 0 0 !important; }
  .section-label { font-size: 12px; color: var(--dim); letter-spacing: 1px; text-transform: uppercase; margin-bottom: 12px; margin-top: 4px; }
  .cat-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 24px; }
  .cat-card { background: var(--bg2); border: 1px solid var(--border); border-radius: 18px; padding: 18px 16px; text-align: left; cursor: pointer; color: var(--text); transition: background 0.15s, transform 0.1s; box-shadow: 0 2px 8px rgba(0,0,0,0.3); -webkit-appearance: none; width: 100%; }
  .cat-card:active { transform: scale(0.96); }
  .cat-icon { font-size: 26px; margin-bottom: 8px; display: block; }
  .cat-count { display: inline-block; border-radius: 8px; padding: 2px 8px; font-size: 20px; font-weight: 800; margin-bottom: 4px; }
  .cat-name { font-size: 12px; color: var(--muted); line-height: 1.3; }
  .siadap-box { background: var(--bg2); border-radius: 16px; padding: 16px; border: 1px solid var(--border); }
  .siadap-row { display: flex; justify-content: space-between; align-items: center; padding: 8px 0; border-bottom: 1px solid rgba(30,58,95,0.3); }
  .siadap-row:last-child { border-bottom: none; }
  .siadap-left { display: flex; gap: 8px; align-items: center; }
  .siadap-ref { font-size: 12px; color: var(--muted); }
  .list-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
  .list-count { font-size: 13px; color: var(--dim); }
  .btn-add { border: none; border-radius: 12px; color: #fff; padding: 8px 16px; font-size: 14px; font-weight: 600; cursor: pointer; display: flex; align-items: center; gap: 6px; -webkit-appearance: none; transition: opacity 0.15s; }
  .btn-add:active { opacity: 0.7; }
  .empty-state { text-align: center; padding: 60px 20px; color: var(--dim); }
  .empty-icon { font-size: 48px; margin-bottom: 12px; }
  .empty-title { font-size: 15px; margin-bottom: 4px; }
  .empty-sub { font-size: 13px; }
  .record-list { display: flex; flex-direction: column; gap: 10px; }
  .record-btn { background: var(--bg2); border: 1px solid var(--border); border-radius: 16px; padding: 16px; text-align: left; cursor: pointer; color: var(--text); display: flex; gap: 14px; align-items: center; width: 100%; -webkit-appearance: none; transition: background 0.15s, transform 0.1s; }
  .record-btn:active { transform: scale(0.97); background: var(--bg3); }
  .record-icon-wrap { width: 42px; height: 42px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 20px; flex-shrink: 0; }
  .record-info { flex: 1; min-width: 0; }
  .record-title { font-weight: 600; font-size: 14px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .record-sub { font-size: 12px; color: var(--dim); margin-top: 2px; }
  .record-arrow { color: var(--dim); font-size: 18px; }
  .report-card { background: var(--bg2); border-radius: 16px; padding: 20px; margin-bottom: 16px; border: 1px solid var(--border); }
  .report-title { font-size: 12px; color: var(--dim); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px; }
  .report-sub { font-size: 13px; color: var(--muted); margin-bottom: 16px; }
  .bar-row { margin-bottom: 14px; }
  .bar-label { display: flex; justify-content: space-between; margin-bottom: 4px; }
  .bar-name { font-size: 13px; }
  .bar-val { font-size: 13px; font-weight: 700; }
  .bar-track { background: #0f172a; border-radius: 8px; height: 8px; overflow: hidden; }
  .bar-fill { height: 100%; border-radius: 8px; transition: width 0.5s ease; }
  .detail-cat { font-size: 13px; font-weight: 700; margin: 0 0 6px; }
  .detail-item { font-size: 12px; color: var(--muted); padding-left: 12px; margin: 0 0 3px; }
  .detail-section { margin-bottom: 16px; }
  .tabbar { position: fixed; bottom: 0; left: 50%; transform: translateX(-50%); width: 100%; max-width: 430px; background: rgba(15,23,42,0.95); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border-top: 1px solid #1e293b; padding: 8px 0 calc(8px + var(--safe-bot)); display: flex; justify-content: space-around; z-index: 50; }
  .tab-btn { background: none; border: none; cursor: pointer; display: flex; flex-direction: column; align-items: center; gap: 3px; padding: 4px 12px; -webkit-appearance: none; }
  .tab-icon { font-size: 22px; }
  .tab-label { font-size: 10px; }
  .back-btn { background: none; border: none; color: var(--blue); font-size: 15px; cursor: pointer; padding: 4px 0; margin-bottom: 8px; display: flex; align-items: center; gap: 4px; -webkit-appearance: none; }
  .overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.7); z-index: 100; display: flex; align-items: flex-end; animation: fadeIn 0.2s ease; }
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
  @keyframes slideUp { from { transform: translateY(100%); } to { transform: translateY(0); } }
  .modal-sheet { background: var(--bg2); border-radius: 24px 24px 0 0; width: 100%; padding: 24px 20px calc(32px + var(--safe-bot)); max-height: 88vh; overflow-y: auto; -webkit-overflow-scrolling: touch; animation: slideUp 0.3s ease; }
  .modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
  .modal-title { font-size: 18px; font-weight: 700; }
  .modal-close { background: var(--border); border: none; border-radius: 10px; width: 32px; height: 32px; color: var(--muted); cursor: pointer; font-size: 18px; display: flex; align-items: center; justify-content: center; -webkit-appearance: none; }
  .field-label { display: block; font-size: 11px; color: var(--dim); margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.8px; }
  .field-wrap { margin-bottom: 16px; }
  input, select, textarea { width: 100%; background: #0f172a; border: 1px solid var(--border); border-radius: 12px; padding: 12px 14px; color: var(--text); font-size: 15px; -webkit-appearance: none; appearance: none; font-family: inherit; }
  input:focus, select:focus, textarea:focus { outline: none; border-color: var(--blue); }
  textarea { resize: none; }
  .btn-save { width: 100%; border: none; border-radius: 14px; padding: 16px; color: #fff; font-size: 16px; font-weight: 700; cursor: pointer; margin-top: 8px; -webkit-appearance: none; transition: opacity 0.15s; }
  .btn-save:active { opacity: 0.8; }
  .detail-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
  .detail-icon-wrap { width: 40px; height: 40px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 20px; }
  .detail-hinfo { margin-left: 10px; }
  .detail-cat-label { font-size: 11px; color: var(--dim); }
  .detail-main-title { font-size: 15px; font-weight: 700; }
  .detail-field { padding: 10px 0; border-bottom: 1px solid var(--border); }
  .detail-field:last-child { border-bottom: none; }
  .detail-field-label { font-size: 11px; color: var(--dim); text-transform: uppercase; margin-bottom: 2px; }
  .detail-field-val { font-size: 14px; }
  .action-btns { display: flex; gap: 10px; margin-top: 20px; }
  .btn-edit { flex: 1; background: var(--border); border: none; border-radius: 12px; padding: 14px; color: var(--text); font-size: 14px; font-weight: 600; cursor: pointer; -webkit-appearance: none; }
  .btn-delete { flex: 1; background: rgba(220,38,38,0.15); border: 1px solid var(--red); border-radius: 12px; padding: 14px; color: var(--red); font-size: 14px; font-weight: 600; cursor: pointer; -webkit-appearance: none; }
  .hidden { display: none !important; }
</style>
</head>
